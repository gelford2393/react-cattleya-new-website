{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/\\.env:env([^/]*)?(/.*)?",
      "destination": "/",
      "permanent": false,
      "statusCode": 404
    }
  ],
  "routes": [
    {
      "src": "/\\..*",
      "dest": "/",
      "status": 404
    },
    {
      "src": "^/(?!.*\\.).*$",
      "dest": "/index.html",
      "status": 200
    }
  ]
}
