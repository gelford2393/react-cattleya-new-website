# Supabase Configuration
# Get these values from your Supabase project settings at https://app.supabase.com
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Gemini API key for the AI chatbot (server-side only, no VITE_ prefix —
# must never be exposed to the browser bundle)
# Get a free-tier key at https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key-here

# Firebase service account key for the cattleyaresort-react booking system
# (server-side only, no VITE_ prefix). Used by the chatbot's checkAvailability
# tool to query real booking data via the Firebase Admin SDK.
# Generate from: Firebase Console > Project Settings > Service Accounts >
# Generate new private key. Base64-encode the downloaded JSON file, e.g.:
#   base64 -i service-account.json | tr -d '\n'
FIREBASE_SERVICE_ACCOUNT_KEY=your-base64-encoded-service-account-json-here

# Add any other environment variables needed for your application below
# Note: In Vite, only variables prefixed with VITE_ are exposed to the client
