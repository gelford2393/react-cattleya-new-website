# Supabase Configuration
# Get these values from your Supabase project settings at https://app.supabase.com
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Groq API key for the AI chatbot (server-side only, no VITE_ prefix —
# must never be exposed to the browser bundle). The chat endpoint streams
# replies from Groq-hosted models (see api/_lib/modelFallback.ts).
# Get a free-tier key at https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# Firebase service account key for the cattleyaresort-react booking system
# (server-side only, no VITE_ prefix). Used by the chatbot's checkAvailability
# tool to query real booking data via the Firebase Admin SDK.
# Generate from: Firebase Console > Project Settings > Service Accounts >
# Generate new private key. Base64-encode the downloaded JSON file, e.g.:
#   base64 -i service-account.json | tr -d '\n'
FIREBASE_SERVICE_ACCOUNT_KEY=your-base64-encoded-service-account-json-here

# Comma-separated allowlist of origins permitted to call the /api/chat endpoint
# (server-side only, no VITE_ prefix). Set this to your real public domain(s),
# e.g. https://cattleyaresort.com. Localhost and the project's own Vercel
# deployment URLs are always allowed automatically, so this is only needed for
# custom domains. Leave unset in local dev.
CHAT_ALLOWED_ORIGINS=https://your-domain.com

# Add any other environment variables needed for your application below
# Note: In Vite, only variables prefixed with VITE_ are exposed to the client
