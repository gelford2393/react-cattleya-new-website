# Supabase Configuration
# Get these values from your Supabase project settings at https://app.supabase.com
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Gemini API key for the AI chatbot (server-side only, no VITE_ prefix —
# must never be exposed to the browser bundle)
# Get a free-tier key at https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key-here

# Add any other environment variables needed for your application below
# Note: In Vite, only variables prefixed with VITE_ are exposed to the client
