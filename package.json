{
  "name": "react-cattleya-new-website",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "copy-tinymce": "node -e \"const fs=require('fs');const path=require('path');const src='node_modules/tinymce';const dst='public/tinymce';fs.rmSync(dst,{recursive:true,force:true});for(const d of['tinymce.min.js','icons','models','plugins','skins','themes']){const s=path.join(src,d);const t=path.join(dst,d);if(fs.statSync(s).isDirectory()){fs.cpSync(s,t,{recursive:true})}else{fs.mkdirSync(dst,{recursive:true});fs.copyFileSync(s,t)}}console.log('TinyMCE assets copied.')\"",
    "build": "npm run copy-tinymce && tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@ai-sdk/groq": "^3.0.42",
    "@ai-sdk/react": "^3.0.211",
    "@hookform/resolvers": "^5.2.2",
    "@supabase/supabase-js": "^2.95.3",
    "@tanstack/react-query": "^5.90.21",
    "@tinymce/tinymce-react": "^6.3.0",
    "add": "^2.0.6",
    "ai": "^6.0.209",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "firebase-admin": "^14.1.0",
    "lucide-react": "^0.563.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.6.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.71.1",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.13.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tinymce": "^8.6.0",
    "yup": "^1.7.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.24",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "shadcn": "^3.8.4",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  }
}
